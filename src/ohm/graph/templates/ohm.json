  "seed_agents": [
    {
      "agent_name": "metis",
      "label": "Metis Research Agent",
      "current_focus": "Synthesizing research findings and identifying knowledge gaps",
      "active_patterns": [
        "research-synthesis",
        "knowledge-gap-analysis",
        "insight-generation"
      ]
    },
    {
      "agent_name": "clio",
      "label": "Clio Research Agent",
      "current_focus": "Conducting domain research and evidence gathering",
      "active_patterns": [
        "research",
        "evidence-gathering",
        "source-verification"
      ]
    },
    {
      "agent_name": "socrates",
      "label": "Socrates Challenge Agent",
      "current_focus": "Challenging claims and identifying logical weaknesses",
      "active_patterns": [
        "critical-analysis",
        "claim-challenging",
        "logical-reasoning"
      ]
    },
    {
      "agent_name": "hephaestus",
